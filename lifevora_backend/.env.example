# ==========================================
# Lifevora Backend — Environment Variables
# Copy this file to .env and fill in your values.
# ==========================================

# Server
PORT=3000
NODE_ENV=development

# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=lifevora_db

# Auth
JWT_SECRET=change_me_to_a_long_random_secret
JWT_EXPIRES_IN=7d
